{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hierologia.dev/schema/event.schema.json",
  "title": "Event",
  "description": "A datable historical happening relevant to a tradition: an ecumenical council, synod, inquisition, expulsion, or the like. One file per event. Shares the provenance and lifecycle model of Concept and Figure.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "tradition", "names", "summary", "sources", "status", "schema_version", "updated"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$", "description": "Stable slug; part of the API URL. Never change once published." },
    "tradition": { "type": "string", "enum": ["islam", "christianity", "judaism", "philosophy"] },
    "names": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary"],
      "properties": {
        "primary": { "type": "string" },
        "original": { "type": "string", "description": "Name in original script." },
        "transliteration": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" } }
      }
    },
    "category": { "type": "string", "description": "Free-form kind, e.g. 'ecumenical council', 'local synod', 'inquisition', 'expulsion'." },
    "location": { "type": "string", "description": "Place, e.g. 'Nicaea, Bithynia'." },
    "date": {
      "type": "object",
      "additionalProperties": false,
      "description": "Approximate is fine; qualify with 'note'.",
      "properties": {
        "year": { "type": "integer", "description": "Year CE the event began (negative for BCE)." },
        "end_year": { "type": "integer", "description": "Year CE the event ended, if it spanned more than one year." },
        "note": { "type": "string" }
      }
    },
    "summary": { "type": "string", "minLength": 1, "description": "One to two neutral sentences." },
    "description": { "type": "string", "description": "Neutral account of what happened and why it mattered. Claims traceable to sources." },
    "editorial_notes": { "type": "string", "description": "Editor notes; served publicly for transparency." },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["convened_by", "participant", "condemned", "affirmed", "produced", "preceded_by", "followed_by", "related_to", "compares_with"]
          },
          "target": { "type": "string", "description": "id of the target entity (may not exist yet)." },
          "note": { "type": "string" }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["citation", "confidence"],
        "properties": {
          "citation": { "type": "string" },
          "url": { "type": "string" },
          "license": { "type": "string" },
          "accessed": { "type": "string", "format": "date" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    },
    "status": { "type": "string", "enum": ["draft", "reviewed", "verified"] },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" }
  }
}
