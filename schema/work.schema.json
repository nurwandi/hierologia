{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hierologia.dev/schema/work.schema.json",
  "title": "Work",
  "description": "A text or document relevant to a tradition: a creed, conciliar definition, treatise, canon, or authoritative collection. One file per work. Shares the provenance and lifecycle model of Concept and Figure.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "tradition", "names", "summary", "sources", "status", "schema_version", "updated"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$", "description": "Stable slug; part of the API URL. Never change once published." },
    "tradition": { "type": "string", "enum": ["islam", "christianity", "judaism", "philosophy"] },
    "names": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary"],
      "properties": {
        "primary": { "type": "string" },
        "original": { "type": "string", "description": "Title in original language or script." },
        "transliteration": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" } }
      }
    },
    "category": { "type": "string", "description": "Free-form kind, e.g. 'creed', 'conciliar definition', 'treatise', 'canon', 'hadith collection'." },
    "date": {
      "type": "object",
      "additionalProperties": false,
      "description": "Composition or adoption year; approximate is fine, qualify with 'note'.",
      "properties": {
        "year": { "type": "integer", "description": "Year CE (negative for BCE)." },
        "note": { "type": "string" }
      }
    },
    "summary": { "type": "string", "minLength": 1, "description": "One to two neutral sentences." },
    "description": { "type": "string", "description": "Neutral account of the work's content and significance. Claims traceable to sources." },
    "editorial_notes": { "type": "string", "description": "Editor notes; served publicly for transparency." },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["authored_by", "adopted_at", "affirms", "condemns", "part_of", "responds_to", "related_to", "compares_with"]
          },
          "target": { "type": "string", "description": "id of the target entity (may not exist yet)." },
          "note": { "type": "string" }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["citation", "confidence"],
        "properties": {
          "citation": { "type": "string" },
          "url": { "type": "string" },
          "license": { "type": "string" },
          "accessed": { "type": "string", "format": "date" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    },
    "status": { "type": "string", "enum": ["draft", "reviewed", "verified"] },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" }
  }
}
