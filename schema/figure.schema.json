{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hierologia.dev/schema/figure.schema.json",
  "title": "Figure",
  "description": "A person: theologian, jurist, traditionist, philosopher, or other historical figure relevant to a tradition. One file per figure. Shares the provenance and lifecycle model of Concept.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "tradition", "names", "summary", "sources", "status", "schema_version", "updated"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$", "description": "Stable slug; part of the API URL. Never change once published." },
    "tradition": { "type": "string", "enum": ["islam", "christianity"] },
    "names": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary"],
      "properties": {
        "primary": { "type": "string" },
        "original": { "type": "string", "description": "Name in original script." },
        "transliteration": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" }, "description": "Kunya, laqab, common English forms, etc." }
      }
    },
    "roles": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Free-form roles, e.g. 'theologian', 'jurist', 'traditionist', 'philosopher'."
    },
    "summary": { "type": "string", "minLength": 1, "description": "One to two neutral sentences." },
    "description": { "type": "string", "description": "Neutral biographical and intellectual sketch. Claims traceable to sources." },
    "editorial_notes": { "type": "string", "description": "Editor notes; served publicly for transparency." },
    "lifespan": {
      "type": "object",
      "additionalProperties": false,
      "description": "Approximate is fine; qualify with 'note'.",
      "properties": {
        "birth": { "type": "integer", "description": "Year CE (negative for BCE)." },
        "death": { "type": "integer" },
        "note": { "type": "string" }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["member_of", "founded", "student_of", "teacher_of", "influenced", "influenced_by", "articulated", "refuted", "contemporary_of", "related_to", "compares_with"]
          },
          "target": { "type": "string", "description": "id of the target entity (may not exist yet)." },
          "note": { "type": "string" }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["citation", "confidence"],
        "properties": {
          "citation": { "type": "string" },
          "url": { "type": "string" },
          "license": { "type": "string" },
          "accessed": { "type": "string", "format": "date" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    },
    "status": { "type": "string", "enum": ["draft", "reviewed", "verified"] },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" }
  }
}
